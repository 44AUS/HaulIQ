# ─── Database ──────────────────────────────────────────────────────────────────
# Railway auto-injects DATABASE_URL — copy it here for local dev
DATABASE_URL=postgresql://user:password@localhost:5432/hauliq

# ─── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=your-super-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── App ───────────────────────────────────────────────────────────────────────
APP_NAME=HaulIQ API
APP_VERSION=1.0.0
DEBUG=false
ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# ─── Fuel price default (USD/gallon) ───────────────────────────────────────────
DEFAULT_FUEL_PRICE=3.85
DEFAULT_MPG=7.2
